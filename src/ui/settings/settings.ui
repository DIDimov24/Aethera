   <string notr="true">
QWidget#Settings { background-color: #eceef5; }
QWidget#settingsHeader { background-color: #eceef5; border-bottom: 1px solid #d4d8ea; }
QLabel#labelSettingsHeaderTitle { color: #1a2440; font-size: 34px; font-weight: 700; letter-spacing: -1px; }
QWidget#pageSettings, QWidget#pageTerms, QWidget#pagePrivacy { background-color: #eceef5; }
QWidget#scrollContentSettings, QWidget#scrollContentTerms, QWidget#scrollContentPrivacy { background: transparent; }
QLabel#labelTermsPageTitle, QLabel#labelPrivacyPageTitle { color: #1a2440; font-size: 34px; font-weight: 700; letter-spacing: -1px; }
QLabel#labelSectionDivider { color: #8898c0; font-size: 9px; font-weight: 700; letter-spacing: 2.5px; }
QFrame#cardUsername, QFrame#cardPassword, QFrame#cardGrade, QFrame#cardBio,
QFrame#cardTermsNav, QFrame#cardPrivacyNav, QFrame#cardTermsContent, QFrame#cardPrivacyContent {
    background-color: #ffffff; border-radius: 12px; border: 1px solid #d4d8ea;
}
QFrame#cardDeleteAccount { background-color: #fdf5f5; border-radius: 12px; border: 1px solid #e8c0c0; }
QLineEdit#inputSettingsUsername, QLineEdit#inputSettingsCurrentPassword,
QLineEdit#inputSettingsNewPassword, QLineEdit#inputSettingsConfirmPassword {
    background-color: #f4f5fa; color: #1a2440; font-size: 14px;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 10px 14px;
}
QLineEdit#inputSettingsUsername:focus, QLineEdit#inputSettingsCurrentPassword:focus,
QLineEdit#inputSettingsNewPassword:focus, QLineEdit#inputSettingsConfirmPassword:focus {
    border: 1px solid #4f6fc4; background-color: #ffffff;
}
QComboBox#comboSettingsGrade {
    background-color: #f4f5fa; color: #1a2440; font-size: 14px;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 10px 14px;
}
QComboBox#comboSettingsGrade:focus {
    border: 1px solid #4f6fc4; background-color: #ffffff;
}
QComboBox#comboSettingsGrade::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border: none;
}
QComboBox#comboSettingsGrade QAbstractItemView {
    background-color: #ffffff;
    color: #1a2440;
    border: 1px solid #d4d8ea;
    selection-background-color: #eef1fb;
    selection-color: #1a2440;
    outline: none;
}
QTextEdit#textSettingsBio {
    background-color: #f4f5fa; color: #1a2440; font-size: 14px;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 10px 14px;
}
QTextEdit#textSettingsBio:focus { border: 1px solid #4f6fc4; background-color: #ffffff; }
QPushButton#buttonSaveUsername, QPushButton#buttonSavePassword, QPushButton#buttonSaveGrade, QPushButton#buttonSaveBio {
    background-color: #4f6fc4; color: #ffffff; font-size: 13px; font-weight: 600;
    border: none; border-radius: 8px; padding: 10px 24px;
}
QPushButton#buttonSaveUsername:hover, QPushButton#buttonSavePassword:hover, QPushButton#buttonSaveGrade:hover, QPushButton#buttonSaveBio:hover {
    background-color: #3a5aae;
}
QPushButton#buttonViewTerms, QPushButton#buttonViewPrivacy {
    background-color: #ffffff; color: #1a2440; font-size: 14px; font-weight: 600;
    border: 1px solid #d4d8ea; border-radius: 10px; padding: 12px 24px; text-align: left;
}
QPushButton#buttonViewTerms:hover, QPushButton#buttonViewPrivacy:hover {
    background-color: #f4f5fa; border-color: #4f6fc4;
}
QPushButton#buttonBackFromTerms, QPushButton#buttonBackFromPrivacy {
    background-color: transparent; color: #8898c0; font-size: 13px; font-weight: 500;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 10px 20px;
}
QPushButton#buttonBackFromTerms:hover, QPushButton#buttonBackFromPrivacy:hover {
    background-color: #eceef5; color: #1a2440; border-color: #b0bcd8;
}
QPushButton#buttonDeleteAccount {
    background-color: #c0392b; color: #ffffff; font-size: 13px; font-weight: 600;
    border: none; border-radius: 8px; padding: 10px 24px;
}
QPushButton#buttonDeleteAccount:hover { background-color: #a93226; }
QLabel#labelSectionUsername, QLabel#labelSectionPassword, QLabel#labelSectionGrade, QLabel#labelSectionBio,
QLabel#labelSectionTermsNav, QLabel#labelSectionPrivacyNav { color: #1a2440; font-size: 16px; font-weight: 600; }
QLabel#labelSectionDelete { color: #c0392b; font-size: 16px; font-weight: 600; }
QLabel#labelFieldNewUsername, QLabel#labelFieldCurrentPw, QLabel#labelFieldNewPw,
QLabel#labelFieldConfirmPw, QLabel#labelFieldGradeDesc, QLabel#labelFieldBioDesc, QLabel#labelFieldTermsDesc,
QLabel#labelFieldPrivacyDesc { color: #8898c0; font-size: 13px; }
QLabel#labelSettingsUsernameStatus, QLabel#labelSettingsPasswordStatus,
QLabel#labelSettingsGradeStatus, QLabel#labelSettingsBioStatus { font-size: 12px; }
QLabel#labelTermsBody, QLabel#labelPrivacyBody { color: #3a4a70; font-size: 13px; }
QLabel#labelDeleteWarning { color: #a93226; font-size: 13px; }
QScrollArea { background: transparent; border: none; }
QScrollBar:vertical { background: #eceef5; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #c0c8e0; border-radius: 4px; min-height: 30px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
