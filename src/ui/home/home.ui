    <string notr="true">
QWidget#centralwidget {
    background-color: #03012D;
}

QWidget#sidebar {
    background-color: #272541;
}

QPushButton#buttonNavDashboard,
QPushButton#buttonNavExams,
QPushButton#buttonSettings {
    background-color: transparent;
    color: #D4D5D9;
    font-size: 14px;
    font-weight: 500;
    border: none;
    border-radius: 6px;
    padding: 10px 16px;
    text-align: left;
}
QPushButton#buttonNavDashboard:hover,
QPushButton#buttonNavExams:hover,
QPushButton#buttonSettings:hover {
    background-color: #302F4B;
    color: #FFFFFF;
}
QPushButton#buttonNavDashboard:pressed,
QPushButton#buttonNavExams:pressed,
QPushButton#buttonSettings:pressed {
    background-color: #03012D;
}

QPushButton#buttonToggleSidebar {
    background-color: transparent;
    color: #D4D5D9;
    font-size: 20px;
    border: none;
    border-radius: 6px;
}
QPushButton#buttonToggleSidebar:hover {
    background-color: #302F4B;
}

QLabel#labelTitle {
    color: #FFFFFF;
    font-size: 32px;
    font-weight: bold;
}
QLabel#labelSubtitle {
    color: #FF7C0A;
    font-size: 16px;
    font-weight: bold;
}
QLabel#labelWelcome {
    color: #AEAEB7;
    font-size: 14px;
}

QWidget#cardExams,
QWidget#cardBest,
QWidget#cardAvg {
    background-color: #272541;
    border-radius: 12px;
}

QLabel#labelCardTitle1,
QLabel#labelCardTitle2,
QLabel#labelCardTitle3 {
    color: #AEAEB7;
    font-size: 12px;
}
QLabel#labelCardValue1,
QLabel#labelCardValue2,
QLabel#labelCardValue3 {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: bold;
}
QLabel#labelCardUnit1 {
    color: #FF7C0A;
    font-size: 13px;
}
QLabel#labelCardUnit2 {
    color: #00D4AA;
    font-size: 13px;
}
QLabel#labelCardUnit3 {
    color: #6C63FF;
    font-size: 13px;
}

QPushButton#buttonStartExam {
    background-color: #FF7C0A;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: bold;
    border: none;
    border-radius: 10px;
    padding: 14px;
}
QPushButton#buttonStartExam:hover {
    background-color: #e06e08;
}
QPushButton#buttonStartExam:pressed {
    background-color: #c46007;
}

QPushButton#buttonLogOut {
    background-color: transparent;
    color: #AEAEB7;
    font-size: 13px;
    border: 1px solid #3D3B5E;
    border-radius: 8px;
    padding: 10px 20px;
}
QPushButton#buttonLogOut:hover {
    background-color: #302F4B;
    color: #FFFFFF;
}

QLabel#labelExamTitle {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: bold;
}
QLabel#labelTimer {
    color: #FF7C0A;
    font-size: 22px;
    font-weight: bold;
}
QLabel#labelQuestion {
    color: #EAEAEA;
    font-size: 16px;
}
QLabel#labelProgress {
    color: #AEAEB7;
    font-size: 13px;
}

QPushButton#buttonA,
QPushButton#buttonB,
QPushButton#buttonC,
QPushButton#buttonD {
    background-color: #272541;
    color: #D4D5D9;
    font-size: 14px;
    border: 1px solid #3D3B5E;
    border-radius: 8px;
    padding: 14px 20px;
    text-align: left;
}
QPushButton#buttonA:hover,
QPushButton#buttonB:hover,
QPushButton#buttonC:hover,
QPushButton#buttonD:hover {
    background-color: #302F4B;
    border-color: #FF7C0A;
    color: #FFFFFF;
}

QPushButton#buttonNext {
    background-color: #FF7C0A;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 12px 30px;
}
QPushButton#buttonNext:hover {
    background-color: #e06e08;
}
QPushButton#buttonNext:disabled {
    background-color: #3D3B5E;
    color: #6B6B80;
}

QProgressBar#progressBar {
    background-color: #1A1836;
    border: none;
    border-radius: 4px;
    height: 8px;
    text-align: center;
    color: transparent;
}
QProgressBar#progressBar::chunk {
    background-color: #FF7C0A;
    border-radius: 4px;
}

QLabel#labelResultTitle {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: bold;
}
QLabel#labelScore {
    color: #FF7C0A;
    font-size: 64px;
    font-weight: bold;
}
QLabel#labelScoreLabel {
    color: #AEAEB7;
    font-size: 14px;
}
QLabel#labelGrade {
    color: #00D4AA;
    font-size: 24px;
    font-weight: bold;
}
QPushButton#buttonRetry,
QPushButton#buttonBackHome {
    background-color: transparent;
    color: #AEAEB7;
    font-size: 14px;
    border: 1px solid #3D3B5E;
    border-radius: 8px;
    padding: 12px 24px;
}
QPushButton#buttonRetry:hover,
QPushButton#buttonBackHome:hover {
    background-color: #302F4B;
    color: #FFFFFF;
}
