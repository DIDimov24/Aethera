   <property name="styleSheet">
    <string notr="true">
QWidget#centralwidget {
    background-color: #161618;
}
QWidget#sidebar {
    background-color: #111113;
    border-right: 1px solid #222224;
}
QLabel#labelTitle {
    color: #ffffff;
    font-size: 34px;
    font-weight: 700;
    letter-spacing: -1px;
}
QLabel#labelSubtitle {
    color: #4a4a52;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
}
QLabel#labelWelcome {
    color: #6b6b76;
    font-size: 13px;
}
QWidget#cardExams,
QWidget#cardBest,
QWidget#cardAvg {
    background-color: #1c1c1f;
    border-radius: 12px;
    border: 1px solid #2a2a2d;
}
QWidget#cardExams:hover,
QWidget#cardBest:hover,
QWidget#cardAvg:hover {
    background-color: #202023;
    border-color: #3a3a3e;
}
QLabel#labelCardTitle1,
QLabel#labelCardTitle2,
QLabel#labelCardTitle3 {
    color: #4a4a52;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
}
QLabel#labelCardValue1,
QLabel#labelCardValue3 {
    color: #ffffff;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -1px;
}
QLabel#labelCardValue2 {
    color: #3dd68c;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -1px;
}
QLabel#labelCardUnit1,
QLabel#labelCardUnit3 {
    color: #4a4a52;
    font-size: 11px;
}
QLabel#labelCardUnit2 {
    color: #2a9e68;
    font-size: 11px;
}
QWidget#divider {
    background-color: #222224;
}
QLabel#labelSectionTitle {
    color: #3a3a3e;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
}
QWidget#heroPanel {
    background-color: #1c1c1f;
    border-radius: 12px;
    border: 1px solid #2a2a2d;
}
QLabel#labelHeroHeading {
    color: #ffffff;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.3px;
}
QLabel#labelHeroDesc {
    color: #4a4a52;
    font-size: 12px;
}
QPushButton#buttonStartExam {
    background-color: #ffffff;
    color: #111113;
    font-size: 13px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    padding: 10px 22px;
}
QPushButton#buttonStartExam:hover {
    background-color: #e8e8e8;
}
QPushButton#buttonStartExam:pressed {
    background-color: #d0d0d0;
}
QPushButton#buttonNext,
QPushButton#buttonRetry {
    background-color: #ffffff;
    color: #111113;
    font-size: 14px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    padding: 12px 28px;
}
QPushButton#buttonNext:hover,
QPushButton#buttonRetry:hover {
    background-color: #e8e8e8;
}
QPushButton#buttonNext:disabled {
    background-color: #1c1c1f;
    color: #3a3a3e;
    border: 1px solid #2a2a2d;
}
QPushButton#buttonBackHome {
    background-color: transparent;
    color: #6b6b76;
    font-size: 14px;
    font-weight: 500;
    border: 1px solid #2a2a2d;
    border-radius: 8px;
    padding: 12px 28px;
}
QPushButton#buttonBackHome:hover {
    background-color: #1c1c1f;
    color: #ffffff;
    border-color: #3a3a3e;
}
QProgressBar#progressBar {
    background-color: #222224;
    border: none;
    border-radius: 2px;
    max-height: 3px;
}
QProgressBar#progressBar::chunk {
    background-color: #ffffff;
    border-radius: 2px;
}
QLabel#labelExamTitle {
    color: #ffffff;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
}
QLabel#labelTimer {
    color: #6b6b76;
    font-size: 17px;
    font-weight: 600;
}
QLabel#labelQuestion {
    color: #e0e0e4;
    font-size: 16px;
}
QLabel#labelProgress {
    color: #3a3a3e;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
}
QLabel#labelResultTitle {
    color: #4a4a52;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
}
QLabel#labelScore {
    color: #3dd68c;
    font-size: 80px;
    font-weight: 700;
    letter-spacing: -4px;
}
QLabel#labelScoreLabel {
    color: #3a3a3e;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
}
QLabel#labelGrade {
    color: #6b6b76;
    font-size: 15px;
    font-weight: 500;
}
QToolTip {
    background-color: #2a2a2d;
    color: #e0e0e4;
    border: 1px solid #3a3a3e;
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 12px;
}
    </string>
