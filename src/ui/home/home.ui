   <property name="styleSheet">
    <string notr="true">
QWidget#centralwidget { background-color: #eceef5; }
QWidget#sidebar { background-color: #f4f5fa; border-right: 1px solid #d8dcea; }
QWidget#sidebarBrand { background-color: #2c3e6b; }
QLabel#labelBrandName { color: #ffffff; font-size: 16px; font-weight: 700; letter-spacing: -0.3px; }
QLabel#labelBrandSub { color: rgba(200,210,240,0.6); font-size: 9px; font-weight: 700; letter-spacing: 2px; }
QWidget#sidebarUserPanel { background-color: #eaf0f8; border-bottom: 1px solid #d0d8ea; }
QLabel#labelSidebarUsername { color: #1a2440; font-size: 13px; font-weight: 600; }
QLabel#labelSidebarGrade { color: #8898c0; font-size: 11px; }
QWidget#sidebarAvatarCircle { background-color: #4f6fc4; border-radius: 17px; min-width: 34px; max-width: 34px; min-height: 34px; max-height: 34px; }
QLabel#labelSidebarAvatarInitial { color: #ffffff; font-size: 13px; font-weight: 700; background: transparent; }
QWidget#topBar { background-color: #2c3e6b; }
QLabel#labelTopBarPage { color: #c8d4f0; font-size: 13px; font-weight: 600; }
QLabel#labelTopBarBreadcrumb { color: rgba(200,212,240,0.45); font-size: 13px; }
QLabel#labelTopBarGrade { color: #a8bce8; font-size: 11px; font-weight: 600; background-color: rgba(79,111,196,0.5); border-radius: 10px; padding: 2px 10px; }
QWidget#labelTopBarAvatar { background-color: #4f6fc4; border-radius: 14px; min-width: 28px; max-width: 28px; min-height: 28px; max-height: 28px; }
QLabel#labelTopBarAvatarText { color: #ffffff; font-size: 12px; font-weight: 700; background: transparent; }
QWidget#topBarLine { background-color: #4f6fc4; }
QLabel#labelTitle { color: #1a2440; font-size: 34px; font-weight: 700; letter-spacing: -1px; }
QLabel#labelSubtitle { color: #8898c0; font-size: 10px; font-weight: 700; letter-spacing: 3px; }
QLabel#labelWelcome { color: #7888b0; font-size: 13px; }
QWidget#cardExams, QWidget#cardBest, QWidget#cardAvg {
    background-color: #ffffff; border-radius: 12px; border: 1px solid #d4d8ea;
}
QWidget#cardExams:hover, QWidget#cardBest:hover, QWidget#cardAvg:hover { border-color: #b0bcd8; }
QLabel#labelCardTitle1, QLabel#labelCardTitle2, QLabel#labelCardTitle3 {
    color: #8898c0; font-size: 9px; font-weight: 700; letter-spacing: 1.5px;
}
QLabel#labelCardValue1, QLabel#labelCardValue3 { color: #1a2440; font-size: 32px; font-weight: 700; letter-spacing: -1px; }
QLabel#labelCardValue2 { color: #4f6fc4; font-size: 32px; font-weight: 700; letter-spacing: -1px; }
QLabel#labelCardUnit1, QLabel#labelCardUnit2, QLabel#labelCardUnit3 { color: #8898c0; font-size: 11px; }
QWidget#divider { background-color: #d4d8ea; }
QLabel#labelSectionTitle, QLabel#labelSectionQuick { color: #8898c0; font-size: 9px; font-weight: 700; letter-spacing: 2.5px; }
QPushButton#buttonQuickExam, QPushButton#buttonQuickHistory {
    background-color: #ffffff; border: 1px solid #d4d8ea; border-radius: 12px; text-align: left; padding: 0px;
}
QPushButton#buttonQuickExam:hover, QPushButton#buttonQuickHistory:hover { border-color: #4f6fc4; }
QPushButton#buttonQuickExam:pressed, QPushButton#buttonQuickHistory:pressed { background-color: #f4f5fa; }
QLabel#labelQuickExamTitle, QLabel#labelQuickHistoryTitle { color: #1a2440; font-size: 13px; font-weight: 600; }
QLabel#labelQuickExamSub, QLabel#labelQuickHistorySub { color: #8898c0; font-size: 11px; }
QWidget#quickExamIcon { background-color: #eef1fb; border-radius: 10px; min-width: 40px; max-width: 40px; min-height: 40px; max-height: 40px; }
QWidget#quickHistoryIcon { background-color: #eaf4ee; border-radius: 10px; min-width: 40px; max-width: 40px; min-height: 40px; max-height: 40px; }
QLabel#labelQuickExamArrow, QLabel#labelQuickHistoryArrow { color: #c0c8e0; font-size: 18px; }
QToolTip { background-color: #2c3e6b; color: #c8d4f0; border: 1px solid #4f6fc4; border-radius: 6px; padding: 4px 8px; font-size: 12px; }
    </string>
