 <class>FlashcardSession</class>
 <widget class="QWidget" name="FlashcardSession">
  <property name="geometry"><rect><x>0</x><y>0</y><width>800</width><height>750</height></rect></property>
  <property name="styleSheet">
   <string notr="true">
QWidget#FlashcardSession { background-color: #eceef5; }
QWidget#sessionHeader { background-color: #eceef5; border-bottom: 1px solid #d4d8ea; }
QLabel#labelSessionTitle { color: #1a2440; font-size: 20px; font-weight: 700; }
QLabel#labelProgress { color: #a0aac8; font-size: 11px; font-weight: 600; letter-spacing: 1px; }
QProgressBar#progressBar { background-color: #dde3f0; border: none; border-radius: 2px; max-height: 3px; }
QProgressBar#progressBar::chunk { background-color: #4f6fc4; border-radius: 2px; }
QWidget#cardFront { background-color: #ffffff; border: 1.5px solid #d4d8ea; border-radius: 14px; }
QWidget#cardBack { background-color: #ffffff; border: 1.5px solid #4f6fc4; border-radius: 14px; }
QLabel#labelCardFront { color: #1a2440; font-size: 22px; font-weight: 700; }
QLabel#labelCardBack { color: #2a6a20; font-size: 18px; font-weight: 600; }
QLabel#labelFrontHint { color: #a0aac8; font-size: 11px; font-weight: 600; letter-spacing: 1px; }
QLabel#labelBackHint { color: #4f6fc4; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; }
QLabel#labelFlipHint { color: #a0aac8; font-size: 12px; }
QPushButton#buttonFlip {
    background-color: #4f6fc4; color: #ffffff; font-size: 14px; font-weight: 600;
    border: none; border-radius: 8px; padding: 12px 28px;
}
QPushButton#buttonFlip:hover { background-color: #3a5aae; }
QPushButton#buttonAgain {
    background-color: #fbeaea; color: #7a2020; font-size: 13px; font-weight: 600;
    border: none; border-radius: 10px; padding: 12px 0;
}
QPushButton#buttonAgain:hover { background-color: #f5dada; }
QPushButton#buttonGood {
    background-color: #e8f5e3; color: #2a6a20; font-size: 13px; font-weight: 600;
    border: none; border-radius: 10px; padding: 12px 0;
}
QPushButton#buttonGood:hover { background-color: #ddf0d6; }
QPushButton#buttonEasy {
    background-color: #eef1fb; color: #2c4890; font-size: 13px; font-weight: 600;
    border: none; border-radius: 10px; padding: 12px 0;
}
QPushButton#buttonEasy:hover { background-color: #e0e6f8; }
QLabel#labelResultComplete { color: #8898c0; font-size: 10px; font-weight: 700; letter-spacing: 3px; }
QLabel#labelResultScore { color: #1a2440; font-size: 52px; font-weight: 800; letter-spacing: -2px; }
QLabel#labelResultSub { color: #4f6fc4; font-size: 16px; font-weight: 600; }
QLabel#labelAgainText, QLabel#labelGoodText, QLabel#labelEasyText { color: #8898c0; font-size: 11px; }
QLabel#labelAgainCount { color: #c0392b; font-size: 20px; font-weight: 700; }
QLabel#labelGoodCount { color: #2a6a20; font-size: 20px; font-weight: 700; }
QLabel#labelEasyCount { color: #4f6fc4; font-size: 20px; font-weight: 700; }
QPushButton#buttonBackToLessons {
    background-color: transparent; color: #8898c0; font-size: 14px; font-weight: 500;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 12px 28px;
}
QPushButton#buttonBackToLessons:hover { background-color: #f4f5fa; color: #1a2440; border-color: #b0bcd8; }
QPushButton#buttonStudyAgain {
    background-color: #4f6fc4; color: #ffffff; font-size: 14px; font-weight: 600;
    border: none; border-radius: 8px; padding: 12px 28px;
}
QPushButton#buttonStudyAgain:hover { background-color: #3a5aae; }
   </string>
