  <property name="styleSheet">
   <string notr="true">
QWidget#FlashcardDeck { background-color: #eceef5; }
QWidget#deckHeader { background-color: #eceef5; border-bottom: 1px solid #d4d8ea; }
QLabel#labelDeckTitle { color: #1a2440; font-size: 20px; font-weight: 700; }
QPushButton#buttonBack {
    background-color: transparent; color: #8898c0; font-size: 13px; font-weight: 500;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 8px 18px;
}
QPushButton#buttonBack:hover { background-color: #f4f5fa; color: #1a2440; border-color: #b0bcd8; }
QLabel#labelSectionCards { color: #8898c0; font-size: 9px; font-weight: 700; letter-spacing: 2.5px; }
QScrollArea { background-color: #eceef5; border: none; }
QScrollBar:vertical { background: #eceef5; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #c0c8e0; border-radius: 4px; min-height: 30px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QWidget#scrollContents { background-color: #eceef5; }
QFrame#addCardFrame { background-color: #ffffff; border: 1px solid #d4d8ea; border-radius: 12px; }
QLabel#labelAddCardTitle { color: #1a2440; font-size: 14px; font-weight: 600; }
QLineEdit#inputFront, QLineEdit#inputBack {
    background-color: #f4f5fa; color: #1a2440; font-size: 13px;
    border: 1px solid #d4d8ea; border-radius: 8px; padding: 10px 14px;
}
QLineEdit#inputFront:focus, QLineEdit#inputBack:focus {
    border: 1px solid #4f6fc4; background-color: #ffffff;
}
QPushButton#buttonAddCard {
    background-color: #4f6fc4; color: #ffffff; font-size: 13px; font-weight: 600;
    border: none; border-radius: 8px; padding: 10px 24px;
}
QPushButton#buttonAddCard:hover { background-color: #3a5aae; }
QLabel#labelAddError { color: #c0392b; font-size: 12px; }
