  <property name="styleSheet">
   <string notr="true">
QWidget#Profile { background-color: #161618; }
QWidget#scrollAreaProfile { background: transparent; border: none; }
QScrollBar:vertical { background: #0f0e1a; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #2e2c50; border-radius: 4px; min-height: 30px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QWidget#avatarCircle { min-width: 116px; max-width: 116px; min-height: 116px; max-height: 116px; background-color: #000000; border-radius: 58px; border: 2px solid #2a2a2d; }
QLabel#labelHeroUsername { color: #FFFFFF; font-size: 26px; font-weight: 700; margin-top: 4px; }
QLabel#labelHeroGrade { color: #6b6b76; font-size: 15px; margin-top: 0px; }
QLabel#labelHeroUsername { color: #FFFFFF; font-size: 22px; font-weight: 700; }
QLabel#labelHeroGrade { color: #6b6b76; font-size: 13px; }
QLabel#labelSectionBio, QLabel#labelSectionAccount { color: #FFFFFF; font-size: 18px; font-weight: 700; }
QLabel#labelSectionText { color: #6b6b76; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }
QLabel#labelBioText, QLabel#labelAccountValue { color: #ffffff; font-size: 18px; }
QLabel#labelBioTextEmpty, QLabel#labelBioTextActual { color: #6b6b76; font-size: 18px; }
QLabel#labelAccountLabel, QLabel#labelFieldUsername, QLabel#labelFieldGrade { color: #6b6b76; font-size: 13px; }
QFrame#bioCard, QFrame#accountCard { background-color: #1c1c1f; border-radius: 12px; border: 1px solid #2a2a2d; }
QFrame#innerDivider { background-color: #2a2a2d; min-height: 1px; max-height: 1px; border: none; }
QPushButton#buttonEditBio, QPushButton#buttonEditUsername, QPushButton#buttonEditGrade { background-color: transparent; color: #c0392b; border: 1px solid #c0392b; border-radius: 8px; padding: 4px 12px; font-size: 13px; font-weight: 600; }
QPushButton#buttonEditBio:hover, QPushButton#buttonEditUsername:hover, QPushButton#buttonEditGrade:hover { background-color: rgba(192, 57, 43, 0.12); }
   </string>
