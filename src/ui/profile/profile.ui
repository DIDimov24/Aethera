  <property name="windowTitle"><string>Profile</string></property>
  <property name="styleSheet">
   <string notr="true">
QWidget#Profile { background-color: #161618; }
QWidget#profileHeader { background-color: #161618; border-bottom: 1px solid #222224; }
QLabel#labelProfileTitle { color: #ffffff; font-size: 34px; font-weight: 700; letter-spacing: -1px; }
QWidget#scrollAreaProfile { background: transparent; border: none; }
QScrollBar:vertical { background: #0f0e1a; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #2e2c50; border-radius: 4px; min-height: 30px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QWidget#avatarCircle { min-width: 88px; max-width: 88px; min-height: 88px; max-height: 88px; background-color: #000000; border-radius: 44px; }
QLabel#labelHeroUsername { color: #ffffff; font-size: 22px; font-weight: 700; }
QLabel#labelHeroGrade { color: #6b6b76; font-size: 13px; }
QLabel#labelSectionBio, QLabel#labelSectionAccount { color: #4a4a52; font-size: 10px; font-weight: 600; letter-spacing: 1.5px; }
QLabel#labelBioText { font-size: 14px; }
QLabel#labelFieldUsername, QLabel#labelFieldGrade { color: #6b6b76; font-size: 13px; min-width: 80px; max-width: 80px; }
QLabel#labelAccountValueUsername, QLabel#labelAccountValueGrade { color: #ffffff; font-size: 14px; }
QFrame#bioCard, QFrame#accountCard { background-color: #1c1c1f; border-radius: 12px; border: 1px solid #2a2a2d; }
QFrame#innerDivider { background-color: #2a2a2d; min-height: 1px; max-height: 1px; border: none; }
QPushButton#buttonEditBio, QPushButton#buttonEditUsername, QPushButton#buttonEditGrade {
    background-color: transparent; color: #c0392b; border: 1px solid #c0392b;
    border-radius: 6px; padding: 3px 10px; font-size: 12px; font-weight: 600;
}
QPushButton#buttonEditBio:hover, QPushButton#buttonEditUsername:hover, QPushButton#buttonEditGrade:hover {
    background-color: rgba(192, 57, 43, 0.12);
}
   </string>
