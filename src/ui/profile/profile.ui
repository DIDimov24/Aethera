<ui version="4.0">
 <class>Profile</class>
 <widget class="QWidget" name="Profile">
  <property name="geometry"><rect><x>0</x><y>0</y><width>800</width><height>750</height></rect></property>
  <property name="windowTitle"><string>Profile</string></property>
  <property name="styleSheet">
   <string notr="true">
QWidget#Profile { background-color: #eceef5; }
QWidget#profileHeader { background-color: #eceef5; border-bottom: 1px solid #d4d8ea; }
QLabel#labelProfileTitle { color: #1a2440; font-size: 34px; font-weight: 700; letter-spacing: -1px; }
QScrollArea#scrollAreaProfile { background-color: #eceef5; border: none; }
QWidget#scrollContentProfile { background-color: #eceef5; }
QScrollBar:vertical { background: #eceef5; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #c0c8e0; border-radius: 4px; min-height: 30px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QPushButton#avatarCircle { min-width: 110px; max-width: 110px; min-height: 110px; max-height: 110px; background-color: #dde3f0; border-radius: 55px; border: none; padding: 0px; }
QPushButton#buttonLogout {
    background-color: transparent; color: #4f6fc4; border: 1px solid #b0bcd8;
    border-radius: 8px; padding: 8px 20px; font-size: 13px; font-weight: 600;
}
QPushButton#buttonLogout:hover { background-color: #eef1fb; border-color: #4f6fc4; }
QLabel#labelHeroUsername { color: #1a2440; font-size: 26px; font-weight: 700; }
QLabel#labelHeroGrade { color: #8898c0; font-size: 13px; }
QLabel#labelSectionBio, QLabel#labelSectionAccount { color: #8898c0; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; }
QLabel#labelBioText { font-size: 14px; color: #3a4a70; background: transparent; }
QLabel#labelFieldUsername, QLabel#labelFieldGrade { color: #8898c0; font-size: 13px; min-width: 80px; max-width: 80px; }
QLabel#labelAccountValueUsername, QLabel#labelAccountValueGrade { color: #1a2440; font-size: 14px; }
QFrame#bioCard, QFrame#accountCard { background-color: #ffffff; border-radius: 12px; border: 1px solid #d4d8ea; }
QFrame#innerDivider { background-color: #d4d8ea; min-height: 1px; max-height: 1px; border: none; }
QPushButton#buttonEditBio, QPushButton#buttonEditUsername, QPushButton#buttonEditGrade {
    background-color: transparent; color: #4f6fc4; border: 1px solid #b0bcd8;
    border-radius: 6px; padding: 3px 10px; font-size: 12px; font-weight: 600;
}
QPushButton#buttonEditBio:hover, QPushButton#buttonEditUsername:hover, QPushButton#buttonEditGrade:hover {
    background-color: #eef1fb; border-color: #4f6fc4;
}
   </string>
